"use client"

import React, { useState, useEffect } from "react"
import { useSwipeable } from "react-swipeable"
import { useRouter, usePathname } from "next/navigation"
import { motion, AnimatePresence } from "framer-motion"

// Порядок твоих страниц. Важно, чтобы пути совпадали с реальными роутами!
const TABS_ORDER = [
  '/qr-scanner',
  '/schedule',
  '/',
  '/reviews',
  '/students'
]

export function SwipeTransition({ children }: { children: React.ReactNode }) {
  const router = useRouter()
  const pathname = usePathname()
  
  // Состояние направления: 1 (свайп влево, идем вперед), -1 (свайп вправо, идем назад), 0 (без анимации)
  const [direction, setDirection] = useState(0)

  // Сбрасываем направление после завершения навигации, чтобы обычные переходы по клику не улетали вбок
  useEffect(() => {
    setDirection(0)
  }, [pathname])

  const currentIndex = TABS_ORDER.indexOf(pathname)

  const handlers = useSwipeable({
    onSwipedLeft: () => {
      if (currentIndex !== -1 && currentIndex < TABS_ORDER.length - 1) {
        setDirection(1) // Анимация выезда слева направо
        router.push(TABS_ORDER[currentIndex + 1])
      }
    },
    onSwipedRight: () => {
      if (currentIndex > 0) {
        setDirection(-1) // Анимация выезда справа налево
        router.push(TABS_ORDER[currentIndex - 1])
      }
    },
    preventScrollOnSwipe: true,
    delta: 40, // Чувствительность свайпа
  })

  // Настройки анимации Framer Motion
  const variants = {
    initial: (dir: number) => ({
      x: dir > 0 ? "100%" : dir < 0 ? "-100%" : "0%",
      opacity: 0,
    }),
    animate: {
      x: "0%",
      opacity: 1,
    },
    exit: (dir: number) => ({
      x: dir < 0 ? "100%" : dir > 0 ? "-100%" : "0%",
      opacity: 0,
    }),
  }

  // Если страница не из футера, просто рендерим как обычно
  if (currentIndex === -1) {
    return <>{children}</>
  }

  return (
    // touch-pan-y блокирует системный жест "назад" в браузере при свайпе по горизонтали
    <div {...handlers} className="w-full min-h-screen relative overflow-x-hidden touch-pan-y">
      {/* mode="popLayout" гарантирует, что старая страница не будет 
        выдавливать новую вниз во время анимации 
      */}
      <AnimatePresence initial={false} custom={direction} mode="popLayout">
        <motion.div
          key={pathname}
          custom={direction}
          variants={variants}
          initial="initial"
          animate="animate"
          exit="exit"
          transition={{
            x: { type: "spring", stiffness: 300, damping: 30 },
            opacity: { duration: 0.2 }
          }}
          className="w-full"
        >
          {children}
        </motion.div>
      </AnimatePresence>
    </div>
  )
}
